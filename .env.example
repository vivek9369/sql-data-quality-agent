# ============================================================
# SQL Data Quality Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env with real secrets to version control!

# --------------- LLM / API Credentials ---------------

# Your Hugging Face token (or OpenAI API key)
HF_TOKEN=hf_your_token_here

# The API endpoint for LLM inference
# Default: HF Inference Routing API (supports many models)
API_BASE_URL=https://router.huggingface.co/v1

# The model to run inference with
# HF examples: meta-llama/Llama-3.3-70B-Instruct
# OpenAI example: gpt-4o-mini
MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct

# --------------- Environment Server ---------------

# The URL where the OpenEnv server (app.py) is running.
# Default: local dev server
ENV_SERVER_URL=http://localhost:7860

# Port for the FastAPI server (Hugging Face Spaces uses 7860)
PORT=7860
